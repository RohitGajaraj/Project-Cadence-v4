# Project-Cadence — environment template.
# Copy to `.env` and fill in real values. `.env` is git-ignored; NEVER commit secrets.
# See AGENTS.md §10 (cross-tool co-development) for how MCP env wiring works.

# --- Supabase: app runtime (client-safe publishable/anon keys) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase: MCP server (consumed by .mcp.json) ---
# Personal access token: https://supabase.com/dashboard/account/tokens
# Server-side only — do NOT expose to the client or commit it.
SUPABASE_ACCESS_TOKEN=
# Project ref = the id in your project URL (e.g. abcdefghijklmnop).
SUPABASE_PROJECT_REF=

# Local-dev AI fallback (KI-06): the cloud injects LOVABLE_API_KEY automatically;
# local dev can instead set a free Google AI Studio key (https://aistudio.google.com
# -> Get API key) to route google/* models directly. Lovable gateway wins if both set.
GEMINI_API_KEY=

# Decision Brain supersession engine (DBR-1.5). OFF by default. When set to 1/true, each
# recorded outcome embeds the decision (one cheap embed) and writes typed
# supersedes/contradicts edges into artifact_lineage (bi-temporal, invalidate-don't-delete).
# Leave empty to keep it dormant: zero AI spend, byte-identical recordOutcome.
DECISION_BRAIN_SUPERSESSION=
