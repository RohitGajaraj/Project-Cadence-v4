# Project-Cadence — environment template.
# Copy to `.env` and fill in real values. `.env` is git-ignored; NEVER commit secrets.
# See AGENTS.md §10 (cross-tool co-development) for how MCP env wiring works.

# --- Supabase: app runtime (client-safe publishable/anon keys) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase: MCP server (consumed by .mcp.json) ---
# Personal access token: https://supabase.com/dashboard/account/tokens
# Server-side only — do NOT expose to the client or commit it.
SUPABASE_ACCESS_TOKEN=
# Project ref = the id in your project URL (e.g. abcdefghijklmnop).
SUPABASE_PROJECT_REF=

# Local-dev AI fallback (KI-06): the cloud injects LOVABLE_API_KEY automatically;
# local dev can instead set a free Google AI Studio key (https://aistudio.google.com
# -> Get API key) to route google/* models directly. Lovable gateway wins if both set.
GEMINI_API_KEY=

# --- AI providers (platform keys — server-side only, never VITE_ prefix) ---
# Cohere embed-v4: embeddings + reranking. 1536 dims (zero migration), 128K token limit,
# EU inference available (eu-west-1). Get key: dashboard.cohere.com → API Keys → New.
# When set, ALL embedding calls route to Cohere instead of the Lovable gateway.
COHERE_API_KEY=

# Fireworks AI: completions (agent loop, chat, Critic). Llama 4 Maverick, $0.15/$0.60/1M.
# 94% cheaper than GPT-4o. Get key: fireworks.ai → API → Create API Key.
# When set, becomes the default completion provider for users without a BYO key.
FIREWORKS_API_KEY=

# Decision Brain supersession engine (DBR-1.5). OFF by default. When set to 1/true, each
# recorded outcome embeds the decision (one cheap embed) and writes typed
# supersedes/contradicts edges into artifact_lineage (bi-temporal, invalidate-don't-delete).
# Leave empty to keep it dormant: zero AI spend, byte-identical recordOutcome.
DECISION_BRAIN_SUPERSESSION=

# --- Observability (AFD initiative — dormant by design) -----------------------
# All three are OPTIONAL. When a key is absent, the matching façade no-ops; user
# flows are never blocked by observability. Even with keys present, traffic is
# additionally gated by the `observability_enabled` app_setting (flip from
# Admin → Observability). See docs/runbooks/observability.md for setup.

# PostHog EU (analytics + session replay + flags). Create the project in the EU
# region (eu.posthog.com) so events stay in-region. Server key starts `phc_`.
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# SEN-05: PostHog INBOUND (product analytics → Cadence signals).
# Distinct from the outbound capture key above. Personal API key from
# PostHog → Settings → Personal API Keys (needs "query:read" scope).
# Also set the project ID from your PostHog project URL.
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# Sentry EU (error capture + performance). DSN from a project hosted on sentry.io
# with EU data residency. Format: https://<key>@<host>/<project-id>.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_SAMPLE_RATE=1.0

# Better Stack (heartbeats + uptime + on-call + status page). Set this to the
# heartbeat BASE URL (without a trailing slug); withJobRun appends `/<job_name>`
# per cron, so one env var covers every job's heartbeat.
BETTER_STACK_HEARTBEAT_URL=
