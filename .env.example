# Project-Cadence — environment template.
# Copy to `.env` and fill in real values. `.env` is git-ignored; NEVER commit secrets.
# See AGENTS.md §10 (cross-tool co-development) for how MCP env wiring works.

# --- Supabase: app runtime (client-safe publishable/anon keys) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase: MCP server (consumed by .mcp.json) ---
# Personal access token: https://supabase.com/dashboard/account/tokens
# Server-side only — do NOT expose to the client or commit it.
SUPABASE_ACCESS_TOKEN=
# Project ref = the id in your project URL (e.g. abcdefghijklmnop).
SUPABASE_PROJECT_REF=
